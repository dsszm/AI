# ============== 管理员配置 ==============
ADMIN_EMAIL=dashuaishizhimao@qq.com

# ============== 鉴权配置 ==============
# 令牌签名密钥(生产环境务必修改为随机字符串,至少 32 位)
TOKEN_SECRET=your-secret-key-here-change-in-production

# ============== SMTP 邮件服务 ==============
# 推荐使用 QQ 邮箱或 163 邮箱
# 
# 【QQ邮箱配置步骤】:
# 1. 登录 QQ 邮箱 → 设置 → 账户
# 2. 开启 "POP3/SMTP服务" 和 "IMAP/SMTP服务"
# 3. 点击 "生成授权码" → 验证密保 → 获取 16 位授权码
# 4. 将授权码填入 SMTP_PASS
# 
# 【163邮箱配置步骤】:
# 1. 登录 163 邮箱 → 设置 → POP3/SMTP/IMAP
# 2. 开启 "POP3/SMTP服务"
# 3. 点击 "设置授权码" → 验证 → 获取授权码
# 4. 将授权码填入 SMTP_PASS

# QQ邮箱配置
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@qq.com
SMTP_PASS=your-16-digit-authorization-code
SMTP_FROM=控制台

# 163邮箱配置(取消注释并注释上方QQ配置即可)
# SMTP_HOST=smtp.163.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your-email@163.com
# SMTP_PASS=your-authorization-code
# SMTP_FROM=控制台

# Gmail配置(国内网络需代理)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=控制台

# ============== 通义千问(可选) ==============
QWEN_API_KEY=
